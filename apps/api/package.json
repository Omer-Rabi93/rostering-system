{
  "name": "@rostering/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint . --config ../../eslint.config.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@rostering/shared": "workspace:*",
    "csv-parse": "^6.1.0",
    "csv-stringify": "^6.6.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "multer": "^2.2.0",
    "pg": "^8.22.0",
    "pg-boss": "^12.26.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^2.2.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}

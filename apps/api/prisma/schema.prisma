// Prisma schema for the Rostering System.
//
// Models, enums, fields, relations, and indexes below are transcribed verbatim
// from docs/design/rostering-system-design.html ("Database Schema" section).
// The `generator`/`datasource` blocks are the only parts NOT dictated by the
// design doc (which assumed an older Prisma major); they are wired to satisfy
// Prisma 7's requirements (explicit generator output, url supplied via
// prisma.config.ts) — see the report for details.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  GENERAL_GUARD
  SUPERVISOR
  SCREENER
}

enum ShiftType {
  A // 00:00–08:00
  B // 08:00–16:00
  C // 16:00–24:00
}

enum WorkerStatus {
  ACTIVE
  INACTIVE
}

enum RosterStatus {
  DRAFT
  PUBLISHED
}

enum AlertType {
  UNFILLABLE_SLOT
  MIN_HOURS_SHORTFALL
}

// v4: per-company CSV import tasks (worker sync + availability sync), tracked as their own
// entity so the queue/task lifecycle (pending/processing/completed/failed/cancelled,
// cancel-and-replace, one-in-flight-per-company+kind) is identical between both CSV kinds --
// see the v4 design doc, Part A ("Key design decisions" / "New ImportTask entity").
enum ImportTaskKind {
  WORKER_SYNC
  AVAILABILITY_SYNC
}

enum ImportTaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model Company {
  id                   Int                   @id @default(autoincrement())
  name                 String                @db.VarChar(120) // unique case-insensitively: raw-SQL migration
  // CREATE UNIQUE INDEX ON companies (lower(name))
  createdAt            DateTime              @default(now())
  workers              Worker[]
  staffingRequirements StaffingRequirement[]
  rosters              Roster[]
  importTasks          ImportTask[]

  @@map("companies")
}

// v4: one row per CSV import attempt (worker sync or availability sync), scoped to a single
// company. `pgBossJobId` cross-references the pg-boss job for cancel-and-replace
// (`boss.cancel(queueName, pgBossJobId)`). `month` is only ever set for AVAILABILITY_SYNC.
// At most one non-terminal (PENDING/PROCESSING) row may exist per (companyId, kind) -- enforced
// by a partial unique index added by hand in this model's migration (Prisma's schema language
// has no first-class way to express a `WHERE` clause on a `@@unique`), since the app-level
// cancel-and-replace sequencing alone isn't sufficient under truly concurrent uploads -- see the
// v4 design doc, Part A's "Cancel-and-replace" section.
model ImportTask {
  id            Int               @id @default(autoincrement())
  companyId     Int
  company       Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  kind          ImportTaskKind
  status        ImportTaskStatus  @default(PENDING)
  pgBossJobId   String?
  month         String?           @db.Char(7) // set for AVAILABILITY_SYNC only
  totalRows     Int?
  processedRows Int?
  insertedCount Int?
  updatedCount  Int?
  failedCount   Int?
  errors        Json?
  createdAt     DateTime          @default(now())
  startedAt     DateTime?
  finishedAt    DateTime?
  workers       Worker[]

  @@index([companyId, kind, status])
  @@index([companyId, kind, finishedAt])
  @@map("import_tasks")
}

model Worker {
  id               Int           @id @default(autoincrement())
  nationalId       String        @unique @db.Char(9) // Israeli ID; checksum checked in Zod
  name             String        @db.VarChar(120)
  companyId        Int // ← employer, required
  company          Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  role             Role
  status           WorkerStatus  @default(ACTIVE)
  shareToken       String        @unique @default(uuid()) // public schedule URL token
  // v4: stamped onto a worker's row every time a WORKER_SYNC CSV row matches/creates/updates
  // them inside an ImportTask that eventually reaches COMPLETED. Only meaningful for
  // WORKER_SYNC tasks; a worker never touched by any worker-CSV import keeps this `null`
  // forever, which is deliberately the "manually managed, always eligible for roster
  // generation" state -- see the v4 design doc, Part A's "Worker.lastImportTaskId" section.
  lastImportTaskId Int?
  lastImportTask   ImportTask?   @relation(fields: [lastImportTaskId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  contract         Contract?
  shiftWorkers     ShiftWorker[]
  availability     WorkerAvailability[]

  @@index([companyId]) // company filters/joins
  @@index([status]) // engine loads ACTIVE workers (see partial index note)
  @@map("workers")
}

model Contract {
  id              Int      @id @default(autoincrement())
  workerId        Int      @unique // ← one contract per worker
  worker          Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  hourlyCostIls   Decimal  @db.Decimal(8, 2) // NOT NULL, ≥ 0 (Zod)
  minMonthlyHours Int // NOT NULL, 0 ≤ min ≤ max (Zod)
  maxMonthlyHours Int
  updatedAt       DateTime @updatedAt

  @@map("contracts")
}

// Availability v2: one row per (worker, calendar date) with the non-empty subset of shifts the
// worker can work that exact date. ABSENCE of a row = unavailable that date — an empty subset is
// never stored (the row is deleted instead). Replaces the old `contracts.availability` weekly
// pattern (dropped in the `availability_v2` migration).
model WorkerAvailability {
  id        Int      @id @default(autoincrement())
  workerId  Int
  // Cascade, matching `Contract`'s delete rule: availability rows are worker-owned auxiliary data
  // with no independent historical value. Roster history stays protected because deleting a worker
  // WITH history is already blocked by `ShiftWorker`'s `onDelete: Restrict` (the deactivate-flow);
  // only a history-less worker can be deleted at all, and then their availability goes with them.
  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  shifts    String   @db.VarChar(3) // canonical subset of "ABC" (e.g. "A", "AB", "ABC"); Zod-validated on write
  updatedAt DateTime @updatedAt

  @@unique([workerId, date]) // one entry per worker per calendar date
  @@index([date]) // month-window queries (date BETWEEN first and last of month)
  @@map("worker_availability")
}

model StaffingRequirement {
  id            Int       @id @default(autoincrement())
  companyId     Int // ← scopes the requirement to one company's own pool, required
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  role          Role
  shift         ShiftType
  requiredCount Int // NOT NULL, ≥ 0

  @@unique([companyId, role, shift]) // ← one row per company × role × shift (≤ 9 rows per company)
  @@index([companyId]) // company filters/joins
  @@map("staffing_requirements")
}

model Roster {
  id          Int          @id @default(autoincrement())
  companyId   Int // ← each company has its own independent roster per month, required
  company     Company      @relation(fields: [companyId], references: [id], onDelete: Restrict)
  month       String       @db.Char(7) // ← "YYYY-MM"; one roster per company per month
  status      RosterStatus @default(DRAFT)
  generatedAt DateTime?
  publishedAt DateTime?
  shifts      Shift[]
  alerts      Alert[]

  @@unique([companyId, month])
  @@index([companyId]) // company filters/joins
  @@map("rosters")
}

model Shift {
  id        Int           @id @default(autoincrement())
  rosterId  Int
  roster    Roster        @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  date      DateTime      @db.Date
  shiftType ShiftType
  workers   ShiftWorker[]

  @@unique([rosterId, date, shiftType]) // ← one row per calendar slot of the month
  @@index([rosterId, date]) // calendar-grid reads
  @@map("shifts")
}

model ShiftWorker {
  shiftId  Int
  shift    Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  workerId Int
  worker   Worker @relation(fields: [workerId], references: [id], onDelete: Restrict)
  role     Role // ← snapshot of worker.role at assignment time

  @@id([shiftId, workerId]) // ← same worker never twice in one slot;
  //   8 h each: cost = count × 8 × rate
  @@index([workerId]) // per-worker schedule + daily-cap checks
  @@map("shift_workers")
}

model Alert {
  id             Int       @id @default(autoincrement())
  rosterId       Int
  roster         Roster    @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  type           AlertType
  detail         Json      @db.JsonB // {date,shift,role} or {workerId,deficitHours}
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?

  @@index([rosterId])
  @@map("alerts")
}

# Copy this file to `.env` and fill in real local values.
# `.env` is tracked in this repo with local-only placeholder credentials (not real secrets) so a
# fresh clone works with `docker compose up` out of the box — don't put real/prod credentials here.

# --- Local dev/test Postgres (docker-compose.dev.yml) ---
# Placeholder values only — safe for a throwaway local container.
#
# Also read by the root docker-compose.yml (Phase 7's nginx+api+worker+postgres stack) for its
# OWN, separate postgres container/volume — reusing the same values is safe because that stack
# runs under its own Compose project name (`name: rostering-prod`), so it never shares a
# container, network, or volume with docker-compose.dev.yml's postgres. POSTGRES_PORT is NOT
# used by docker-compose.yml — its postgres is intentionally not published on any host port.
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=dbname
POSTGRES_PORT=5432

# --- apps/api (Prisma, seed script, integration-test harness) ---
# Must match the POSTGRES_* values above when pointed at docker-compose.dev.yml.
# NOT read by docker-compose.yml directly — that stack builds its own DATABASE_URL from the
# POSTGRES_* values above with the internal service hostname `postgres` instead of `localhost`
# (see docker-compose.yml's `x-database-url` anchor).
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Silences dotenv's stdout "tip" line (cosmetic only).
DOTENV_CONFIG_QUIET=true
